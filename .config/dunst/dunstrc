[global]
  follow = keyboard
  width = 350
  height = 300
  origin = top-right
  offset = 0x26
  scale = 0
  notification_limit = 0

  progress_bar = true
  progress_bar_height = 20
  progress_bar_frame_width = 1
  progress_bar_min_width = 150
  progress_bar_max_width = 350
  progress_bar_horizontal_alignment = right

  indicate_hidden = yes
  transparency = 0
  separator_height = 3
  separator_color = frame
  padding = 7
  horizontal_padding = 7
  text_icon_padding = 7
  frame_width = 3
  frame_color = "#ffffff"
  sort = yes
  idle_threshold = 120

  font = JetBrainsMono 11
  markup = full
  alignment = left 
  vertical_alignment = top
  show_age_threshold = 60
  ellipsize = middle
  ignore_newline = no
  stack_duplicates = true
  hide_duplicate_count = false
  show_indicators = yes

  icon_position = left
  min_icon_size = 52
  max_icon_size = 52
  enable_recursive_icon_lookup = true
  icon_theme = Standard, hicolor

  sticky_history = yes
  history_length = 50

  browser = /usr/bin/xdg-open
  always_run_script = true
  title = Dunst
  class = Dunst
  corner_radius = 0
  ignore_dbusclose = false

  mouse_left_click = close_current
  mouse_middle_click = do_action, close_current
  mouse_right_click = close_all

  script = ~/.local/opt/play-dunst-notification-sound

[urgency_low]
  timeout = 10

[urgency_normal]
  timeout = 10

[urgency_critical]
  timeout = 0

[volume_brightness]
  category = volume_brightness
  alignment = left
  timeout = 1

[popup-log]
  category = popup-log
  timeout = 0

[nm-applet]
  desktop_entry = "nm-applet"
  urgency = "normal"

[global]
  icon_theme = Thewebmasterp, hicolor
  highlight = "#FFE987"

[urgency_low]
  background = "#001d7570"
  foreground = "#f0f4ff"
  frame_color = "#00a600"

[urgency_normal]
  background = "#00a60070"
  foreground = "#f0f4ff"
  frame_color = "#FFE987"


[urgency_critical]
  background = "#FF104170"
  foreground = "#f0f4ff"
  frame_color = "#FF1041"

[normal]
  msg_urgency = "normal"
  background = "#00a60070"
  foreground = "#f0f4ff"
  frame_color = "#FFE987"